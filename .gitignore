# Generic .gitignore
# Compiled source
*.o
*.obj
*.so
*.dll
*.exe
*.out
*.class

# Lua compiled files
*.luac

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.venv/

# Build directories
build/
dist/
target/

# OS files
.DS_Store
Thumbs.db

# Editor/project files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
*.iml

# Logs and runtime files
*.log
logs/
*.pid
*.seed

# Secrets and env
.env
.env.local
.env.*.local

# Archives
*.zip
*.tar.gz
*.rar

# Temporary files
*.swp
*~
*.tmp
*.bak

# Coverage
coverage/
.coverage

# Terraform
.terraform/

# Misc
npm-debug.log
yarn-debug.log

# macOS
.DS_Store

# JetBrains
.idea/

# Visual Studio
.vs/

# Ignore node modules if present
node_modules/

# Ignore compiled Lua bytecode
*.luac
